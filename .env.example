# Environment variables

# Runtime
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="HybridTurtle"
APP_TIMEZONE="Europe/London"

# Database
# Stable runtime path in this workspace uses SQLite.
# For a future Postgres migration, replace with a postgresql:// URL once the Prisma provider is migrated.
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"
CRON_SECRET="set-a-strong-random-secret"

# Market Data — Yahoo Finance (no API key needed!)
MARKET_DATA_PROVIDER="yahoo"
# EODHD API key (optional fallback — required only when MARKET_DATA_PROVIDER=eodhd)
# EODHD_API_KEY="your-eodhd-api-key"

# Broker adapter: disabled (safe default), mock (demo data), trading212 (live)
BROKER_ADAPTER="disabled"

# Telegram Bot (optional — for trade alerts)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# Trading 212 API Keys (optional — alternative to storing in DB via Settings page)
# If set, these take priority over database values. Settings page shows as read-only.
# T212_INVEST_API_KEY=
# T212_ISA_API_KEY=
# T212_INVEST_ACCOUNT_ID=
# T212_ISA_ACCOUNT_ID=
# T212_ENVIRONMENT=live
ENABLE_BROKER_TRADING="false"
ENABLE_AUTO_SUBMISSION="false"

# Nightly Run Schedule (cron expression - 9:30 PM UK)
NIGHTLY_CRON="30 21 * * *"

# Alerts / ML
ENABLE_TELEGRAM_ALERTS="false"
MODEL_SERVICE_URL="http://localhost:8000"
ENABLE_ML_SCORING="false"
